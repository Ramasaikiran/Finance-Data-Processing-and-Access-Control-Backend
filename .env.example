# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
DB_PATH=./finance.db

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_strong_random_secret
JWT_EXPIRES_IN=24h

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# Leave blank to run in dev mode — emails are printed to the terminal instead.
# Set all four for a real provider.
#
# Gmail:  SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_USER=you@gmail.com  SMTP_PASS=app_password
# Resend: SMTP_HOST=smtp.resend.com SMTP_PORT=587  SMTP_USER=resend          SMTP_PASS=re_xxx
#
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Finance App <noreply@financeapp.local>

# Base URL used to build the verification link in emails
APP_URL=http://localhost:3000
